# ArtLink 프론트엔드 환경 변수 예시
# 이 파일을 복사하여 .env로 사용하세요 (Vite는 VITE_ 접두사 변수만 클라이언트에 노출)

# 카카오 OAuth REST API 키 (https://developers.kakao.com)
VITE_KAKAO_CLIENT_ID=your-kakao-rest-api-key

# Instagram OAuth — Instagram App ID (Meta 앱 > Instagram > API setup with Instagram login)
VITE_INSTAGRAM_APP_ID=your-instagram-app-id
