generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 사용자 모델
model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String
  nickname   String?  @unique  // 공개 표시명 (설정 시 이름 대신 노출), 중복 불가
  role       String   // ARTIST, GALLERY, ADMIN
  avatar     String?
  phone      String?  // 가입 시 입력받는 연락처 (기존 유저는 null 허용)
  instagramUrl String? // 작가 프로필 인스타그램 주소 (선택)
  password   String?  // bcrypt hash (LOCAL auth only)
  provider   String   @default("LOCAL") // LOCAL, KAKAO, NAVER, GOOGLE
  providerId String?  // OAuth provider user ID
  deletedAt  DateTime? // 회원탈퇴(소프트 삭제) 시각. null 아니면 로그인 차단 + 공개 표시 '탈퇴한 회원'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([provider, providerId])

  // Relations
  galleries      Gallery[]
  reviews        Review[]
  favorites      Favorite[]
  portfolio      Portfolio?
  applications   Application[]
  notifications  Notification[]
  inquiries      Inquiry[]
  portfolioImageLikes PortfolioImageLike[]
  sentMessages     Message[]       @relation("sentMessages")
  receivedMessages Message[]       @relation("receivedMessages")
  messageReports   MessageReport[] @relation("messageReports")
  exhibitionSubmissions ExhibitionSubmission[]
}

// 갤러리 모델
model Gallery {
  id          Int      @id @default(autoincrement())
  name        String
  address     String
  phone       String
  description String
  detailDesc  String?  // 상세 소개 (승인 후 수정 가능)
  region      String   // SEOUL, GYEONGGI_NORTH, GYEONGGI_SOUTH, DAEJEON, BUSAN
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectReason String?
  ownerName   String
  mainImage   String?
  instagramUrl            String?  // 인스타그램 주소 (@handle) — 연동 시 저장, 연결 해제 전까지 유지
  instagramAccessToken    String?  // Instagram 장기 액세스 토큰(60일, 서버 전용) — OAuth로 발급
  instagramTokenExpiresAt DateTime? // 장기 토큰 만료 시각 — 만료 임박 시 갱신
  instagramFeedVisible    Boolean  @default(false) // 피드 공개 여부
  instagramProfileVisible Boolean  @default(false) // 프로필 링크 공개 여부
  email       String?  // 갤러리 이메일 주소
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ownerId     Int
  owner       User         @relation(fields: [ownerId], references: [id])
  images      GalleryImage[]
  exhibitions Exhibition[]
  shows       Show[]
  reviews     Review[]
  favorites   Favorite[]
  galleryOfMonth GalleryOfMonth?

  @@index([ownerId])
  @@index([status, region])
  @@index([rating])
}

// 갤러리 이미지
model GalleryImage {
  id        Int      @id @default(autoincrement())
  url       String
  order     Int      @default(0)
  galleryId Int
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
}

// 공모 사진 (다중, 순서변경 가능) — 첫 사진(order 최소)이 대표 이미지로 imageUrl과 동기화
model ExhibitionImage {
  id           Int        @id @default(autoincrement())
  url          String
  order        Int        @default(0)
  exhibitionId Int
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)

  @@index([exhibitionId])
}

// 전시/공모 모델
model Exhibition {
  id          Int      @id @default(autoincrement())
  title       String
  type        String   // SOLO, GROUP, ART_FAIR
  deadline    DateTime // 공모 마감일
  deadlineStart DateTime? // 공모 시작일
  exhibitDate DateTime // 전시 종료일
  exhibitStartDate DateTime? // 전시 시작일
  capacity    Int
  region      String
  description String
  imageUrl    String?  // 공모 대표 이미지
  customFields String? // 커스텀 질문 항목 (JSON 문자열: [{id, label, type, required, options}])
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED (승인 상태)
  rejectReason String?
  recruitmentClosed Boolean @default(false) // 모집마감 (수동 내림 → 목록 비노출)
  confirmed   Boolean  @default(false)      // 확정 (작가 전시정보 수정 잠금). 전시 시작일 경과 시 자동 확정 처리
  ended       Boolean  @default(false)      // 전시종료 (정산 단계)
  settlementRequestedAt DateTime?            // 정산 확인 요청 시각. non-null=작가 확인 대기(정산 수정 잠금 + 작가에게 검토 공개)
  settledAt   DateTime?                      // 정산 완료 시각. non-null=정산 확정(운영페이지 수정 잠금 + 작가에게 정산 공개)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  galleryId   Int
  gallery     Gallery     @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  applications Application[]
  favorites    Favorite[]
  promoPhotos  PromoPhoto[]
  images       ExhibitionImage[]
  messages     Message[]
  reviews      Review[]
  notices      ExhibitionNotice[]
  submissions  ExhibitionSubmission[]
  sales        ArtworkSale[]
  settlements  ArtistSettlement[]
  settlementApprovals SettlementApproval[]

  @@index([galleryId])
  @@index([status, deadline])
  @@index([region])
}

// 전시 종료 후 홍보 사진
model PromoPhoto {
  id           Int        @id @default(autoincrement())
  url          String
  caption      String?
  exhibitionId Int
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

// 히어로 슬라이드
model HeroSlide {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String
  linkUrl     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 혜택
model Benefit {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  linkUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 이달의 갤러리
model GalleryOfMonth {
  id        Int      @id @default(autoincrement())
  galleryId Int      @unique
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  title     String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// 리뷰
model Review {
  id        Int      @id @default(autoincrement())
  rating    Int      // 1-5
  content   String
  imageUrl  String?
  anonymous Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  galleryId Int
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  exhibitionId Int?
  exhibition   Exhibition? @relation(fields: [exhibitionId], references: [id], onDelete: SetNull)

  @@index([galleryId])
  @@index([userId])
}

// 찜하기
model Favorite {
  id           Int         @id @default(autoincrement())
  userId       Int
  user         User        @relation(fields: [userId], references: [id])
  galleryId    Int?
  gallery      Gallery?    @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  exhibitionId Int?
  exhibition   Exhibition? @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  showId       Int?
  show         Show?       @relation(fields: [showId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@unique([userId, galleryId])
  @@unique([userId, exhibitionId])
  @@unique([userId, showId])
  @@index([userId])
}

// 포트폴리오
model Portfolio {
  id              Int              @id @default(autoincrement())
  biography       String?
  exhibitionHistory String?        // (구) 전시이력 단일 텍스트 — career로 대체, 하위호환 위해 컬럼 유지
  career          String?          // 경력 JSON: { artFair:[{year,content}], solo:[...], group:[...] }
  portfolioFileUrl String?         // 포트폴리오 파일(pdf/doc/hwp) URL
  userId          Int              @unique
  user            User             @relation(fields: [userId], references: [id])
  images          PortfolioImage[]
  updatedAt       DateTime         @updatedAt
}

// 포트폴리오 이미지
model PortfolioImage {
  id            Int       @id @default(autoincrement())
  url           String
  order         Int       @default(0)
  showInExplore Boolean   @default(false)
  portfolioId   Int
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  likes         PortfolioImageLike[]
}

// 포트폴리오 이미지 좋아요
model PortfolioImageLike {
  id        Int            @id @default(autoincrement())
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageId   Int
  image     PortfolioImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([userId, imageId])
  @@index([imageId])
  @@index([userId])
}

// 지원
model Application {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  exhibitionId Int
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  customAnswers String?   // (구) 커스텀 질문 답변 — 고정 양식으로 대체, 하위호환 위해 컬럼 유지
  biography    String?    // 지원 시 작가 약력 (필수)
  career       String?    // 지원 시 경력 JSON: { artFair:[{year,content}], solo:[...], group:[...] }
  artworkImages String?   // 지원 시 작품 사진 URL 배열 JSON (최대 10, 1장 이상 필수)
  portfolioFileUrl String? // 지원 시 포트폴리오 파일(pdf/doc/hwp) URL
  status       String     @default("SUBMITTED") // SUBMITTED, REVIEWED, ACCEPTED, REJECTED
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt @default(now()) // 상태 변경(수락/거절 등) 시각 추적

  @@unique([userId, exhibitionId])
  @@index([userId])
}

// 전시 (갤러리의 실제 전시/행사 소개)
model Show {
  id            Int         @id @default(autoincrement())
  title         String
  description   String
  startDate     DateTime
  endDate       DateTime
  openingHours  String      // "10:00-18:00"
  admissionFee  String      // "무료" or "5,000원"
  location      String
  region        String      // SEOUL, GYEONGGI_NORTH 등 (필터용)
  artists       String?     // JSON: ["작가1","작가2"]
  posterImage   String
  status        String      @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectReason  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  galleryId     Int
  gallery       Gallery     @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  images        ShowImage[]
  favorites     Favorite[]

  @@index([galleryId])
  @@index([status, region])
}

// 전시 추가 이미지
model ShowImage {
  id     Int    @id @default(autoincrement())
  url    String
  order  Int    @default(0)
  showId Int
  show   Show   @relation(fields: [showId], references: [id], onDelete: Cascade)
}

// 인앱 알림
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // APPLICATION_STATUS, NEW_APPLICANT, APPROVAL_RESULT
  message   String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

// 자주 묻는 질문 (Admin 작성, 전체 공개)
model Faq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 1:1 문의
model Inquiry {
  id        Int       @id @default(autoincrement())
  subject   String
  content   String
  status    String    @default("OPEN") // OPEN, ANSWERED
  reply     String?
  repliedAt DateTime?
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// 승인 요청 (갤러리/공모 수정 요청)
model ApprovalRequest {
  id          Int      @id @default(autoincrement())
  type        String   // GALLERY_EDIT, EXHIBITION_EDIT
  targetId    Int      // galleryId or exhibitionId
  changes     String   // JSON string of requested changes
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectReason String?
  requesterId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

// 메시지 (Artist ↔ Gallery 소통)
model Message {
  id           Int         @id @default(autoincrement())
  subject      String
  content      String
  read         Boolean     @default(false)
  senderId     Int
  sender       User        @relation("sentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId   Int
  receiver     User        @relation("receivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  exhibitionId Int?
  exhibition   Exhibition? @relation(fields: [exhibitionId], references: [id], onDelete: SetNull)
  attachments  String?
  createdAt    DateTime    @default(now())
  reports      MessageReport[]

  @@index([receiverId, read])
  @@index([senderId])
  @@index([exhibitionId])
  @@index([createdAt])
}

// 메시지 신고
model MessageReport {
  id         Int      @id @default(autoincrement())
  messageId  Int
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporterId Int
  reporter   User     @relation("messageReports", fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String
  detail     String?
  status     String   @default("PENDING")
  adminNote  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([messageId, reporterId])
  @@index([status])
  @@index([createdAt])
}

// 공모 운영 페이지 — 갤러리 공지사항
model ExhibitionNotice {
  id           Int        @id @default(autoincrement())
  exhibitionId Int
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  title        String
  content      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt @default(now())

  @@index([exhibitionId])
}

// 공모 운영 페이지 — 수락 작가가 제출하는 전시 정보 (출품리스트/작가약력/작가노트)
model ExhibitionSubmission {
  id           Int        @id @default(autoincrement())
  exhibitionId Int
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  userId       Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artworkList  String?    // JSON: [{image,title,size,medium,year,price}]
  cv           String?    // JSON: {nameKo,nameEn,birth,tel,email,education[],solo[],group[],artFair[],award[]} (각 항목 [{year,content}])
  note         String?    // JSON: {statement, sections:[{title,body}]}
  representativeIndex Int? // 엽서용 대표작 — artworkList 내 인덱스 (작가가 선택, null=미선택)
  updatedAt    DateTime   @updatedAt @default(now())

  @@unique([exhibitionId, userId])
  @@index([exhibitionId])
}

// 판매된 작품 (전시종료 후 갤러리가 입력) — 작가 출품리스트의 index 기준
model ArtworkSale {
  id           Int        @id @default(autoincrement())
  exhibitionId Int
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artistUserId Int
  artworkIndex Int        // 해당 작가 artworkList 내 인덱스
  title        String     // 작품명 스냅샷
  soldPrice    Int        // 판매가 (원)
  paymentMethod String    @default("CARD") // CARD(카드) | CASH(현금)

  @@unique([exhibitionId, artistUserId, artworkIndex])
  @@index([exhibitionId])
}

// 작가별 정산 비율 (전시종료 후 갤러리가 입력) — galleryRatio: 갤러리 몫 %, 작가 = 100 - galleryRatio
model ArtistSettlement {
  id           Int        @id @default(autoincrement())
  exhibitionId Int
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artistUserId Int
  galleryRatio Int        @default(0) // 0~100

  @@unique([exhibitionId, artistUserId])
  @@index([exhibitionId])
}

// 정산 확인 승인 — 갤러리가 [정산 확인 요청] 시 수락 작가별 1행 생성. 전원 APPROVED여야 갤러리가 정산 완료 가능.
model SettlementApproval {
  id           Int        @id @default(autoincrement())
  exhibitionId Int
  exhibition   Exhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  artistUserId Int
  status       String     @default("PENDING") // PENDING(미응답) | APPROVED(수락) | ISSUE(문제제기)
  comment      String?    // 문제 제기 시 갤러리에 전달할 코멘트
  updatedAt    DateTime   @updatedAt @default(now())

  @@unique([exhibitionId, artistUserId])
  @@index([exhibitionId])
}
