# ArtLink 환경 변수 예시
# 이 파일을 복사하여 .env로 사용하세요

# Database (PostgreSQL)
DATABASE_URL="postgresql://artlink:artlink_dev_password@localhost:5432/artlink?connection_limit=20&pool_timeout=10"
# connection_limit: Prisma 커넥션 풀 크기 (기본 10, 권장 20)
# pool_timeout: 커넥션 대기 타임아웃 초 (기본 10)
# 배포 예시: DATABASE_URL="postgresql://user:pass@rds-endpoint:5432/artlink?connection_limit=20&pool_timeout=10"

# JWT
JWT_SECRET="your-secret-key-here"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# 개발자 로그인 (로컬 전용) — 로그인 페이지의 Admin/Gallery/Artist 빠른 로그인 버튼이
# 실제로 동작하려면 반드시 true로 설정해야 함. 없거나 false면 /auth/dev-login이 404를 반환한다.
# (프론트는 import.meta.env.DEV일 때 버튼을 항상 렌더하므로, 이 값이 없으면 버튼이 보여도 로그인 실패)
# production에서는 절대 설정 금지.
ENABLE_DEV_LOGIN=true

# 로컬 E2E 편의: rate limit 비활성화 (운영에선 절대 설정 금지)
# DISABLE_RATE_LIMIT=true

# File Upload
UPLOAD_DIR="uploads"

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=artlink-images
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# OAuth - 카카오 (https://developers.kakao.com)
KAKAO_CLIENT_ID=your-kakao-rest-api-key

# Instagram OAuth (Instagram API with Instagram Login — 비즈니스/크리에이터 계정)
# Meta 앱 대시보드 > Instagram > API setup with Instagram login 의 값
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
